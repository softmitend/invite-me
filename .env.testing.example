APP_NAME=InviteMe
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

BCRYPT_ROUNDS=4

DB_CONNECTION=pgsql
# Use a separate Neon branch/database for tests.
DB_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DB_SSLMODE=require

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

MIDTRANS_SERVER_KEY=sandbox-server-key
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
