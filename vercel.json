{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "LARAVEL_STORAGE_PATH": "/tmp/inviteme-storage",
        "VIEW_COMPILED_PATH": "/tmp/inviteme-storage/framework/views",
        "APP_CONFIG_CACHE": "/tmp/inviteme-storage/framework/cache/config.php",
        "APP_EVENTS_CACHE": "/tmp/inviteme-storage/framework/cache/events.php",
        "APP_PACKAGES_CACHE": "/tmp/inviteme-storage/framework/cache/packages.php",
        "APP_ROUTES_CACHE": "/tmp/inviteme-storage/framework/cache/routes.php",
        "APP_SERVICES_CACHE": "/tmp/inviteme-storage/framework/cache/services.php"
    },
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.8.0"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
